{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "http://example.com/example.json",
  "type": "object",
  "title": "Gateway Variables Schema",
  "description": "JSON Schema for the list of gateway-related variables (private, public, egress, waypoint, HPA).",
  "definitions": {
    "integerOrString": {
      "anyOf": [
        { "type": "integer" },
        { "type": "string" }
      ]
    },
    "booleanOrString": {
      "anyOf": [
        { "type": "boolean" },
        { "type": "string" }
      ]
    }
  },
  "properties": {
