      "title": "The ISTIO_PRIVATE_GATEWAY_NAME schema",
      "description": "Name of the private Istio gateway.",
      "default": "private-gateway",
      "internal": true
    },
    "ISTIO_PUBLIC_GATEWAY_NAME": {
      "$id": "#/properties/ISTIO_PUBLIC_GATEWAY_NAME",
      "type": "string",
      "title": "The ISTIO_PUBLIC_GATEWAY_NAME schema",
      "description": "Name of the public Istio gateway.",
      "default": "public-gateway",
      "internal": true
    },
    "PUBLIC_FB_SERVICE_NAME": {
      "$id": "#/properties/PUBLIC_FB_SERVICE_NAME",
      "type": "string",
      "title": "The PUBLIC_FB_SERVICE_NAME schema",
      "description": "Name of the public fallback service.",
      "default": "public-fallback-service",
      "internal": true
    },
    "PRIVATE_FB_SERVICE_NAME": {
      "$id": "#/properties/PRIVATE_FB_SERVICE_NAME",
      "type": "string",
      "title": "The PRIVATE_FB_SERVICE_NAME schema",
